# NOTE: .env.production IS committed intentionally.
# It only contains VITE_API_URL (a public URL, not a secret).
# This is needed so Vercel can pick it up during the build.
# Real secrets (MONGO_URI, JWT_SECRET) must be set in Vercel dashboard.

